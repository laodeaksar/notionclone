{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter web build",
  "outputDirectory": ".svelte-kit",
  "framework": "sveltekit",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_API_VERCEL_URL/api/:path*"
    }
  ],
  "env": {
    "PUBLIC_LIVEBLOCKS_KEY": "@public_liveblocks_key"
  }
}
