{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env dev --port 3000",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply laodeaksar --local",
    "db:migrate:prod": "wrangler d1 migrations apply laodeaksar --remote",
    "db:seed": "wrangler d1 execute laodeaksar --local --file=seeds/seed.sql",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@liveblocks/node": "^3.0.0",
    "@notion-clone/auth": "workspace:*",
    "@notion-clone/db": "workspace:*",
    "@notion-clone/schemas": "workspace:*",
    "hono": "^4.7.11",
    "nanoid": "^5.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.3",
    "wrangler": "^3.114.4"
  }
}
