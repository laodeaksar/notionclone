    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "dependencies": {
    "pnpm": "^11.5.0"
  }
}
