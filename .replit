modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["pn", "nano"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DB Migrate"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DB Seed"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DB Migrate (Prod)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'NODE_BIN=\"/nix/store/bl6iwirn83qj9r8wng43kfdqd5mfahj8-nodejs-22.22.0/bin\"; export PATH=\"$NODE_BIN:/home/runner/workspace/.npm-global/bin:$PATH\"; pnpm --filter web dev'"
waitForPort = 5000

[[workflows.workflow]]
name = "Start API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api dev"
waitForPort = 3000

[[workflows.workflow]]
name = "DB Migrate"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api db:migrate"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "DB Seed"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api db:seed"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "DB Migrate (Prod)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api db:migrate:prod"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[userenv]

[userenv.shared]
BETTER_AUTH_URL = "https://3c448997-bdf0-4f05-beb3-9d3d44199b2b-00-xe3hsltqa4ef.sisko.replit.dev"
ALLOWED_ORIGINS = "https://3c448997-bdf0-4f05-beb3-9d3d44199b2b-00-xe3hsltqa4ef.sisko.replit.dev"

[userenv.development]
NODE_ENV = "development"

[userenv.production]
NODE_ENV = "production"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "pnpm --filter api start & pnpm --filter web preview --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "pnpm install && pnpm --filter web build"]
